# Supabase project URL and public anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-side only, NEVER prefix with NEXT_PUBLIC_ and never
# import into client components. Used for privileged writes (e.g. creating orders).
SUPABASE_SERVICE_ROLE_KEY=

# --- Notifications (F4). Leave unset to use the built-in log adapter, which
# records deliveries in the notifications table without sending anything. ---
# NOTIFY_PROVIDER=log            # log | whatsapp | sms
# WhatsApp (Meta Cloud API):
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_API_VERSION=v21.0
# SMS (Twilio):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1...

# --- Error monitoring (F5t). Optional HTTP collector for captured errors
# (Sentry tunnel / Slack webhook / Logtail). Unset = console-only. ---
# MONITORING_WEBHOOK_URL=

# --- Feature flags (XC-045), all default ON. Set to false to disable. ---
# NEXT_PUBLIC_FLAG_OWNER_DASHBOARD=true
# NEXT_PUBLIC_FLAG_REALTIME=true
# FLAG_NOTIFICATIONS=true
