# Supabase project URL and public anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-side only, NEVER prefix with NEXT_PUBLIC_ and never
# import into client components. Used for privileged writes (e.g. creating orders).
SUPABASE_SERVICE_ROLE_KEY=
