# Supabase project URL and public anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-side only, NEVER prefix with NEXT_PUBLIC_ and never
# import into client components. Used for privileged writes (e.g. creating orders).
SUPABASE_SERVICE_ROLE_KEY=

# --- Public site base URL. Used to build ABSOLUTE links in customer messages
# (e.g. the order-tracking link in WhatsApp). Set to your live domain, no
# trailing slash. On Vercel it falls back to VERCEL_PROJECT_PRODUCTION_URL. ---
# NEXT_PUBLIC_SITE_URL=https://hioc.in

# --- Notifications (F4). Leave unset to use the built-in log adapter, which
# records deliveries in the notifications table without sending anything. ---
# NOTIFY_PROVIDER=log            # log | whatsapp | sms
# WhatsApp (Meta Cloud API):
# WHATSAPP_TOKEN=          # permanent System-User token
# WHATSAPP_PHONE_ID=       # the Phone number ID (NOT the WABA/App ID)
# WHATSAPP_API_VERSION=v21.0
# Approved template names (defaults shown; override if you named them differently):
# WHATSAPP_TPL_ACCEPTED=order_accepted
# WHATSAPP_TPL_READY=order_ready
# WHATSAPP_TPL_REJECTED=order_rejected
# WHATSAPP_TPL_CANCELLED=order_cancelled
# WHATSAPP_TPL_LANG=en
# Webhook (delivery/read receipts at /api/whatsapp/webhook):
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=   # you pick this; paste the SAME value into Meta's "Verify token"
# WHATSAPP_APP_SECRET=             # App settings > Basic > App Secret (optional signature check)
# Login OTP over WhatsApp (Supabase "Send SMS Hook" → /api/auth/sms-hook):
# WHATSAPP_OTP_TEMPLATE=login_code # your approved Authentication template name
# SUPABASE_SEND_SMS_HOOK_SECRET=   # the secret Supabase shows when you enable the Send SMS Hook (v1,whsec_...)
# SMS (Twilio):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1...

# --- Error monitoring (F5t). Optional HTTP collector for captured errors
# (Sentry tunnel / Slack webhook / Logtail). Unset = console-only. ---
# MONITORING_WEBHOOK_URL=

# --- Vercel Cron secret (H5). Set this to a long random string in the Vercel
# project's Environment Variables. Vercel automatically sends it as
# `Authorization: Bearer <CRON_SECRET>` on cron invocations of
# /api/cron/expire-orders (configured in vercel.json), which the route checks.
# CRON_SECRET=

# --- Feature flags (XC-045), all default ON. Set to false to disable. ---
# NEXT_PUBLIC_FLAG_OWNER_DASHBOARD=true
# NEXT_PUBLIC_FLAG_REALTIME=true
# FLAG_NOTIFICATIONS=true

# --- Payments (FND-1/PAY-1..3) — Razorpay, called via REST (no SDK dep). ---
# Leave ALL of these unset to disable online payment entirely: checkout falls
# back to "Pay at counter" only, and the online-payment UI is hidden.
# Server-side key pair (Basic auth for Orders/Refunds API calls):
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# HMAC secret configured on the Razorpay webhook (Dashboard > Webhooks),
# pointed at POST /api/payments/webhook:
# RAZORPAY_WEBHOOK_SECRET=
# Public key id handed to the client-side checkout.js widget — safe to
# expose to the browser (usually the same value as RAZORPAY_KEY_ID):
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
